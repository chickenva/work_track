<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>WELGUN - Hệ Thống Quản Lý Chấm Công</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/admin.css" />

  </head>
  <body>
    <div class="admin-container">
      <!-- Header -->
      <div class="header">
        <h1>QUẢN LÝ NHÂN VIÊN</h1>
        <div class="header-right">
          <span style="color: #7f8c8d; font-weight: 600"
            >Xin chào, <strong><%= user.fullName %></strong></span
          >
          <a href="/logout" class="logout-btn">ĐĂNG XUẤT</a>
        </div>
      </div>

      <!-- Tabs -->
      <div class="tabs-container">
        <div class="tabs-nav">
          <button class="tab-button active" onclick="switchTab('list', this)">
            DANH SÁCH NHÂN VIÊN
          </button>
          <button class="tab-button" onclick="switchTab('add', this)">
            THÊM / SỬA NHÂN VIÊN
          </button>
          <button class="tab-button" onclick="switchTab('detail', this)">
            CHI TIẾT THÔNG TIN
          </button>
        </div>

        <!-- Tab: Danh Sách Nhân Viên -->
        <div id="tab-list" class="tab-content active">
          <div class="search-box">
            <input
              type="text"
              id="searchInput"
              placeholder="Tìm kiếm theo mã nhân viên hoặc tên..."
              onkeyup="filterEmployees()"
            />
          </div>
          <div class="table-wrapper">
            <table class="employee-table" id="employeeTable">
              <thead>
                <tr>
                  <th>Mã Nhân Viên</th>
                  <th>Họ và Tên</th>
                  <th>Vị Trí</th>
                  <th>Số Ngày Làm</th>
                  <th>Số Ngày Nghỉ</th>
                  <th>Trạng Thái</th>
                  <th>Hành Động</th>
                </tr>
              </thead>
              <tbody id="employeeTableBody">
                <tr>
                  <td colspan="7" class="text-center py-5">
                    <span style="color: #7f8c8d">Đang tải dữ liệu...</span>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Tab: Thêm / Sửa Nhân Viên -->
        <div id="tab-add" class="tab-content">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <h3 style="color: #2c3e50; margin: 0;">
              <span id="formTitle">THÊM NHÂN VIÊN MỚI</span>
            </h3>
            <div style="display: flex; gap: 10px; align-items: center;">
              <button
                type="button"
                id="deleteBtn"
                onclick="deleteEmployee()"
                style="display: none; background-color: #e74c3c; color: white; border: none; padding: 8px 16px; border-radius: 5px; cursor: pointer; font-weight: bold; font-size: 14px;"
              >
                XÓA
              </button>
              <button
                type="button"
                id="lockBtn"
                onclick="toggleLockEmployee()"
                style="display: none; background-color: #f39c12; color: white; border: none; padding: 8px 16px; border-radius: 5px; cursor: pointer; font-weight: bold; font-size: 14px;"
              >
                KHÓA
              </button>
              <button
                type="button"
                id="cancelEditBtn"
                class="btn-cancel"
                onclick="cancelEdit()"
                style="display: none; padding: 8px 16px; font-size: 14px;"
              >
                HỦY
              </button>
            </div>
          </div>
          <form id="employeeForm">
            <!-- Thông Tin Cá Nhân -->
            <div style="margin-bottom: 30px; border: 1px solid #bdc3c7; border-radius: 8px; padding: 20px; background-color: #f8f9fa;">
              <h4 style="color: #2c3e50; margin-bottom: 20px; font-weight: bold; border-bottom: 2px solid #3498db; padding-bottom: 10px;">
                THÔNG TIN CÁ NHÂN
              </h4>

              <div class="form-grid">
                <div class="form-group">
                  <label>Mã Nhân Viên</label>
                  <input
                    type="text"
                    id="employeeId"
                    placeholder="Tự động sinh"
                    readonly
                  />
                </div>
                <div class="form-group">
                  <label>Họ và Tên *</label>
                  <input
                    type="text"
                    id="fullName"
                    placeholder="Nhập họ và tên"
                    required
                  />
                </div>
              </div>

              <div class="form-grid">
                <div class="form-group">
                  <label>Số Điện Thoại *</label>
                  <input
                    type="tel"
                    id="phone"
                    placeholder="Nhập số điện thoại"
                    required
                  />
                </div>
                <div class="form-group">
                  <label>Vị Trí *</label>
                  <input
                    type="text"
                    id="position"
                    placeholder="Nhập vị trí công việc"
                    required
                  />
                </div>
              </div>

              <div class="form-grid">
                <div class="form-group">
                  <label>Số Ngày Làm *</label>
                  <input
                    type="number"
                    id="workingDays"
                    placeholder="Nhập số ngày làm"
                    value="0"
                    readonly
                    required
                  />
                </div>
                <div class="form-group">
                  <label>Số Ngày Nghỉ *</label>
                  <input
                    type="number"
                    id="dayOff"
                    placeholder="Nhập số ngày nghỉ"
                    value="0"
                    readonly
                    required
                  />
                </div>
              </div>
            </div>

            <!-- Thông Tin Tài Khoản -->
            <div style="margin-bottom: 30px; border: 1px solid #bdc3c7; border-radius: 8px; padding: 20px; background-color: #f8f9fa;">
              <h4 style="color: #2c3e50; margin-bottom: 20px; font-weight: bold; border-bottom: 2px solid #e74c3c; padding-bottom: 10px;">
                THÔNG TIN TÀI KHOẢN
              </h4>

              <div class="form-grid">
                <div class="form-group">
                  <label>Tên Tài Khoản *</label>
                  <input
                    type="text"
                    id="username"
                    placeholder="Nhập tên tài khoản"
                    required
                  />
                </div>
                <div class="form-group">
                  <label>Mật Khẩu *</label>
                  <input
                    type="password"
                    id="password"
                    placeholder="Nhập mật khẩu"
                    required
                  />
                </div>
              </div>

              <div class="form-grid">
                <div class="form-group">
                  <label>Vai Trò *</label>
                  <select id="role" required>
                    <option value="user">Nhân Viên</option>
                    <option value="admin">Quản Lý</option>
                  </select>
                </div>
                <div class="form-group">
                  <label>Trạng Thái Tài Khoản</label>
                  <input
                    type="text"
                    id="accountStatus"
                    value="Hoạt động"
                    readonly
                  />
                </div>
              </div>
            </div>

            <div class="button-group" id="buttonGroup" style="gap: 10px;">
              <button
                type="button"
                class="btn-submit"
                id="submitBtn"
                onclick="submitEmployeeForm()"
                style="flex: 1;"
              >
                THÊM NHÂN VIÊN
              </button>
              <button
                type="button"
                class="btn-cancel"
                id="resetBtn"
                onclick="resetEmployeeForm()"
                style="display: none;"
              >
                RESET
              </button>
            </div>
          </form>
        </div>

        <!-- Tab: Chi tiết thông tin nhân viên -->
        <div id="tab-detail" class="tab-content">
          <div id="detailTabContent">
            <p style="color: #7f8c8d; text-align: center; padding: 40px;">
              Chọn một nhân viên từ danh sách để xem chi tiết thông tin
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Detail Modal -->
    <div
      id="detailModal"
      class="modal-overlay"
      onclick="closeDetailModal(event)"
    >
      <div class="modal-content" onclick="event.stopPropagation()">
        <div class="modal-header">
          <span>CHI TIẾT THÔNG TIN NHÂN VIÊN</span>
          <button class="close-modal" onclick="closeDetailModal()"></button>
        </div>
        <div id="detailContent"></div>
      </div>
    </div>

    <!-- Report Detail Modal -->
    <div
      id="reportDetailModal"
      class="modal-overlay"
      onclick="closeReportDetailModal(event)"
    >
      <div class="modal-content" onclick="event.stopPropagation()">
        <div class="modal-header">
          <span>CHI TIẾT BÁO CÁO</span>
          <button class="close-modal" onclick="closeReportDetailModal()"></button>
        </div>
        <div id="reportDetailContent"></div>
      </div>
    </div>

    <!-- Image Viewer Modal -->
    <div
      id="imageViewerModal"
      class="modal-overlay"
      onclick="closeImageViewerModal(event)"
    >
      <div class="modal-content" onclick="event.stopPropagation()" style="max-width: 600px;">
        <div class="modal-header">
          <span id="imageViewerTitle"></span>
          <button class="close-modal" onclick="closeImageViewerModal()"></button>
        </div>
        <img id="viewerImg" src="" style="width: 100%; border-radius: 5px;" />
      </div>

    <!-- Report Detail Modal -->
    <div id="reportDetailModal" class="report-detail-modal" onclick="closeReportDetailModal(event)">
      <div class="modal-content" onclick="event.stopPropagation()">
        <div class="modal-header">
          <span>CHI TIẾT BÁO CÁO</span>
          <button class="close-modal" onclick="closeReportDetailModal()"></button>
        </div>
        <div id="reportDetailContent"></div>
      </div>
    </div>

    <!-- Image Viewer Modal -->
    <div id="imageViewerModal" class="image-viewer-modal" onclick="closeImageViewerModal(event)">
      <div class="image-viewer-content" onclick="event.stopPropagation()">
        <div class="image-viewer-title" id="imageViewerTitle"></div>
        <img id="viewerImg" class="image-viewer-img" src="" alt="Preview" />
        <div style="display: flex; gap: 10px; justify-content: center; margin-top: 15px;">
          <button onclick="downloadImage()" style="background-color: #3498db; color: white; border: none; padding: 8px 15px; border-radius: 5px; cursor: pointer; font-weight: bold;">⬇️ Tải về</button>
          <button class="close-modal" onclick="closeImageViewerModal()" style="background-color: #95a5a6; color: white; border: none; padding: 8px 15px; border-radius: 5px; cursor: pointer; font-weight: bold;">Đóng</button>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/admin.js"></script>
  </body>
</html>




